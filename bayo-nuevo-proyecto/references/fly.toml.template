app = 'APP_NAME'
primary_region = 'cdg'
kill_signal = 'SIGTERM'

[build]

[env]
  PHX_HOST = 'APP_NAME.fly.dev'
  PHX_SERVER = 'true'
  PORT = '8080'

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = 'stop'
  auto_start_machines = true
  min_machines_running = 0
  processes = ['app']

  [http_service.concurrency]
    type = 'connections'
    hard_limit = 1000
    soft_limit = 1000

[[vm]]
  memory = '512mb'
  cpu_kind = 'shared'
  cpus = 1
